NODE_ENV=production
PORT=3010

MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/padel-proactive-db

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TLS=false

WHATSAPP_QUEUE_NAME=whatsapp:commands
WORKER_CONCURRENCY=2

WORKER_HEARTBEAT_INTERVAL_MS=10000
WORKER_HEARTBEAT_STALE_MS=30000

PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
WA_REMOTE_HTML=https://raw.githubusercontent.com/wppconnect-team/wa-version/main/html/2.2412.54.html

# Si querés forwardear mensajes entrantes al backend
BACKEND_INTERNAL_URL=
BACKEND_INTERNAL_TOKEN=
